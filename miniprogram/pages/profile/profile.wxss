.container {
  min-height: 100vh;
  background: #fff;
}

.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
  background: #f0f0f0;
}

.nickname {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
}

.info-list {
  padding: 0 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #eee;
}

.info-label {
  width: 180rpx;
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  word-break: break-all;
}

.copy-icon {
  width: 36rpx;
  height: 36rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.notice-section {
  padding: 40rpx 32rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}
