.container {
  padding: 0 0 160rpx 0;
  min-height: 100vh;
  background: #f6f6f6;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-btn {
  background: #4CAF50;
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
}

.clear-btn {
  background: #f0f0f0;
  color: #666;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
}

/* Tab 筛选栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #4CAF50;
  color: #fff;
  font-weight: 500;
}

/* 课程列表 */
.course-list {
  padding: 24rpx;
}

.day-group {
  margin-bottom: 32rpx;
}

.day-header {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #4CAF50;
}

/* 课程卡片 */
.course-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s;
}

.course-card:active {
  transform: scale(0.98);
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.course-time {
  font-size: 26rpx;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.course-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  text-align: center;
}

/* 底部悬浮按钮 */
.fab-btn {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #4CAF50;
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab-btn:active {
  transform: translateX(-50%) scale(0.95);
}

.fab-icon {
  font-size: 40rpx;
  font-weight: 300;
  margin-right: 8rpx;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 500;
}
