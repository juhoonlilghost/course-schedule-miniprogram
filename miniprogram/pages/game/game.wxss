/* game.wxss */
page {
  background-color: #f6f6f6;
}

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Score Bar */
.score-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.score-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 400;
}

.score-value {
  font-size: 48rpx;
  color: #4CAF50;
  font-weight: bold;
}

/* Canvas */
.canvas-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.game-canvas {
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  background-color: #1a1a1a;
}

/* Control Row */
.control-row {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* Buttons */
.btn {
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
}

.btn-primary:active {
  background-color: #3d8b40;
}

/* D-pad */
.d-pad {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.d-pad-row {
  display: flex;
  gap: 10rpx;
}

.d-btn {
  width: 120rpx;
  height: 120rpx;
  background-color: #fff;
  border: 2rpx solid #4CAF50;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.d-btn:active {
  background-color: #e8f5e9;
}

.d-btn-empty {
  background-color: transparent;
  border-color: transparent;
}

.d-btn-text {
  font-size: 40rpx;
  color: #4CAF50;
}

/* Game Over Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 70%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-score-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.modal-score {
  font-size: 64rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 40rpx;
}

.modal-btn {
  width: 100%;
  text-align: center;
}
