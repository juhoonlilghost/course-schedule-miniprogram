/* rank.wxss */
page {
  background-color: #f6f6f6;
}

.page {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* Best Score Card */
.best-card {
  background: linear-gradient(135deg, #66BB6A, #4CAF50);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}

.best-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
}

.best-score {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
}

/* Section Title */
.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* Empty State */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* Leaderboard List */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* Rank Badge */
.rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  background-color: #ccc;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-badge-1 {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.rank-badge-2 {
  background: linear-gradient(135deg, #C0C0C0, #A9A9A9);
}

.rank-badge-3 {
  background: linear-gradient(135deg, #CD7F32, #B87333);
}

/* Avatar */
.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 4rpx solid #f0f0f0;
}

.avatar-placeholder {
  font-size: 28rpx;
  font-weight: 500;
  color: #4CAF50;
}

/* Name */
.rank-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Score */
.rank-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-left: 20rpx;
  flex-shrink: 0;
}
