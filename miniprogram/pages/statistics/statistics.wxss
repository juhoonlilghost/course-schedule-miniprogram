.container {
  min-height: 100vh;
  background: #f6f6f6;
  padding-bottom: 40rpx;
}

.page-header {
  background: #4CAF50;
  padding: 40rpx 0;
  text-align: center;
}

.page-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.loading-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

.overview-cards {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #4CAF50;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.distribution-section {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.day-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.day-name {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
  text-align: right;
  margin-right: 16rpx;
}

.day-bar-wrap {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.day-bar {
  height: 100%;
  background: #4CAF50;
  border-radius: 12rpx;
  transition: width 0.5s ease;
}

.day-count {
  width: 80rpx;
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}
